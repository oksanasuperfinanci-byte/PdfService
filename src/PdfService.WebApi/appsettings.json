{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FileStorage": {
    "BasePath": "./temp-storage",
    "FileLifetimeHours": 2,
    "MaxFileSizeMb": 100
  },
  "Gotenberg": {
    "BaseUrl": "http://localhost:3000",
    "TimeoutSeconds": 180
  }
}
