{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FileStorage": {
    "BasePath": "./temp-storage",
    "FileLifetimeHours": 2,
    "MaxFileSizeMb": 100,
    "MaxTotalUploadSizeMb": 200,
    "WorkerCount": 2,
    "ExternalProcessTimeoutSeconds": 180
  }
}
